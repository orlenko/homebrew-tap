#!/usr/bin/env bash

set -euo pipefail

# move-pr-diff — re-base a PR's diff onto a new target branch as a fresh PR.
#
# Generates the diff of an existing PR and re-applies it on a new branch (the
# original source branch name + a numeric suffix) targeting a different base
# branch, then opens a fresh PR for it.

usage() {
    cat <<'EOF'
move-pr-diff — re-base a PR's diff onto a new target branch as a fresh PR.

  move-pr-diff <PR_URL> <new_target_branch>

Example:
  move-pr-diff https://github.com/owner/repo/pull/1605 release-2.0

Requires an authenticated gh, plus git and jq. Run inside the target repo.
EOF
}

case "${1:-}" in
    -h|--help) usage; exit 0 ;;
esac

if [ $# -ne 2 ]; then
    usage >&2
    exit 1
fi

PR_URL="$1"
NEW_TARGET_BRANCH="$2"

# Extract PR number and repo from URL
# Format: https://github.com/owner/repo/pull/NUMBER
if [[ ! "$PR_URL" =~ ^https://github\.com/([^/]+)/([^/]+)/pull/([0-9]+)$ ]]; then
    echo "Error: Invalid PR URL format. Expected: https://github.com/owner/repo/pull/NUMBER"
    exit 1
fi

REPO_OWNER="${BASH_REMATCH[1]}"
REPO_NAME="${BASH_REMATCH[2]}"
PR_NUMBER="${BASH_REMATCH[3]}"
REPO="${REPO_OWNER}/${REPO_NAME}"

echo "Processing PR #${PR_NUMBER} from ${REPO}"

# Get PR information using GitHub CLI
echo "Fetching PR information..."
PR_INFO=$(gh pr view "$PR_NUMBER" --repo "$REPO" --json headRefName,baseRefName,title,body,headRepositoryOwner,headRepositoryName)

ORIGINAL_SOURCE_BRANCH=$(echo "$PR_INFO" | jq -r '.headRefName')
ORIGINAL_TARGET_BRANCH=$(echo "$PR_INFO" | jq -r '.baseRefName')
PR_TITLE=$(echo "$PR_INFO" | jq -r '.title')
PR_BODY=$(echo "$PR_INFO" | jq -r '.body // ""')
HEAD_REPO_OWNER=$(echo "$PR_INFO" | jq -r '.headRepositoryOwner.login')
HEAD_REPO_NAME=$(echo "$PR_INFO" | jq -r '.headRepositoryName')

echo "Original source branch: ${ORIGINAL_SOURCE_BRANCH}"
echo "Original target branch: ${ORIGINAL_TARGET_BRANCH}"
echo "New target branch: ${NEW_TARGET_BRANCH}"

# Determine the new branch name with numeric suffix
# Extract base name and find next available suffix
BASE_BRANCH_NAME="$ORIGINAL_SOURCE_BRANCH"
NEW_BRANCH_NAME="${BASE_BRANCH_NAME}-02"

# Check if branch already exists and increment suffix if needed
SUFFIX=2
while git ls-remote --heads origin "$NEW_BRANCH_NAME" &>/dev/null || \
      git show-ref --verify --quiet refs/heads/"$NEW_BRANCH_NAME" 2>/dev/null; do
    SUFFIX=$((SUFFIX + 1))
    NEW_BRANCH_NAME="${BASE_BRANCH_NAME}-$(printf "%02d" $SUFFIX)"
done

echo "New branch name: ${NEW_BRANCH_NAME}"

# Ensure we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: Not in a git repository"
    exit 1
fi

# Fetch latest changes
echo "Fetching latest changes..."
git fetch origin

# Check if new target branch exists
if ! git ls-remote --heads origin "$NEW_TARGET_BRANCH" &>/dev/null && \
   ! git show-ref --verify --quiet refs/heads/"$NEW_TARGET_BRANCH" 2>/dev/null; then
    echo "Error: Target branch '${NEW_TARGET_BRANCH}' does not exist locally or remotely"
    exit 1
fi

# Create temporary file for diff
TEMP_DIFF=$(mktemp)
trap "rm -f $TEMP_DIFF" EXIT

# Generate diff using GitHub CLI (most reliable method)
echo "Generating diff from PR #${PR_NUMBER}..."
if ! gh pr diff "$PR_NUMBER" --repo "$REPO" > "$TEMP_DIFF"; then
    echo "Warning: Failed to get diff from GitHub CLI, trying git diff..."
    # Fallback: try git diff with various branch combinations
    git fetch origin "$ORIGINAL_SOURCE_BRANCH" "$ORIGINAL_TARGET_BRANCH" 2>/dev/null || true
    
    if git show-ref --verify --quiet "refs/remotes/origin/${ORIGINAL_TARGET_BRANCH}" 2>/dev/null && \
       git show-ref --verify --quiet "refs/remotes/origin/${ORIGINAL_SOURCE_BRANCH}" 2>/dev/null; then
        git diff "origin/${ORIGINAL_TARGET_BRANCH}..origin/${ORIGINAL_SOURCE_BRANCH}" > "$TEMP_DIFF"
    elif git show-ref --verify --quiet "refs/heads/${ORIGINAL_TARGET_BRANCH}" 2>/dev/null && \
         git show-ref --verify --quiet "refs/heads/${ORIGINAL_SOURCE_BRANCH}" 2>/dev/null; then
        git diff "${ORIGINAL_TARGET_BRANCH}..${ORIGINAL_SOURCE_BRANCH}" > "$TEMP_DIFF"
    else
        echo "Error: Could not find branches to generate diff"
        exit 1
    fi
fi

# Check if diff is empty
if [ ! -s "$TEMP_DIFF" ]; then
    echo "Warning: Diff is empty. There may be no changes between branches."
fi

# Create new branch from new target branch
echo "Creating new branch ${NEW_BRANCH_NAME} from ${NEW_TARGET_BRANCH}..."
git checkout -b "$NEW_BRANCH_NAME" "origin/${NEW_TARGET_BRANCH}" 2>/dev/null || \
git checkout -b "$NEW_BRANCH_NAME" "$NEW_TARGET_BRANCH"

# Apply the diff
echo "Applying diff..."
if [ -s "$TEMP_DIFF" ]; then
    if ! git apply "$TEMP_DIFF"; then
        echo "Warning: Failed to apply diff cleanly. You may need to resolve conflicts manually."
        echo "Diff has been saved to: $TEMP_DIFF"
        # Continue anyway - user can resolve conflicts manually
    fi
else
    echo "No changes to apply (empty diff)"
fi

# Stage and commit changes if there are any
if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "Staging changes..."
    git add -A
    echo "Committing changes..."
    git commit -m "Apply diff from PR #${PR_NUMBER} (${ORIGINAL_SOURCE_BRANCH} -> ${ORIGINAL_TARGET_BRANCH})" || {
        echo "Warning: No changes to commit or commit failed"
    }
fi

# Push the new branch
echo "Pushing branch ${NEW_BRANCH_NAME}..."
git push -u origin "$NEW_BRANCH_NAME"

# Prepare PR description with added note
PR_DESCRIPTION="${PR_BODY}"
if [ -n "$PR_DESCRIPTION" ]; then
    PR_DESCRIPTION="${PR_DESCRIPTION}

---
This is a copy of [PR #${PR_NUMBER}](${PR_URL}) re-made against the new target: \`${NEW_TARGET_BRANCH}\`."
else
    PR_DESCRIPTION="This is a copy of [PR #${PR_NUMBER}](${PR_URL}) re-made against the new target: \`${NEW_TARGET_BRANCH}\`."
fi

# Create new PR
echo "Creating new PR..."
# gh pr create prints the new PR's URL on stdout (it has no --output/--json flag).
NEW_PR_URL=$(gh pr create \
    --repo "$REPO" \
    --base "$NEW_TARGET_BRANCH" \
    --head "$NEW_BRANCH_NAME" \
    --title "$PR_TITLE" \
    --body "$PR_DESCRIPTION")

echo ""
echo "Success! New PR created:"
echo "$NEW_PR_URL"
