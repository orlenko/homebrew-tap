# IMAP connection — point at any server.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true                     # false when using STARTTLS
IMAP_STARTTLS=false                  # true for Proton Mail Bridge
IMAP_TLS_REJECT_UNAUTHORIZED=true    # false to accept a self-signed cert (Bridge)
IMAP_USER=you@gmail.com
IMAP_PASSWORD=your-app-password

IMAP_FOLDER=INBOX                    # optional; can be passed as the 1st CLI arg
# TARGET_DIR=/some/other/dir         # optional; defaults to the current directory
# IMAP_MARK_READ=true                # mark messages read (RFC822); default leaves them unread (BODY.PEEK)
